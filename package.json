{
  "name": "obsidian-crdt-sync-server",
  "private": true,
  "packageManager": "bun@1.3.10",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "build": "bun build src/index.ts --outfile=main.js --target=bun --minify",
    "check": "biome check --write .",
    "dev": "bun --watch src/index.ts",
    "prepare": "husky",
    "release": "bun run release.ts",
    "start": "bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hocuspocus/server": "3.4.4",
    "valibot": "1.2.0",
    "yjs": "13.6.29"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@hocuspocus/provider": "3.4.4",
    "@types/bun": "1.3.10",
    "@types/ws": "^8.18.1",
    "husky": "9.1.7",
    "typescript": "5.9.3"
  }
}
