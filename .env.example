# Required: static auth token for WebSocket connections, generate with `openssl rand -base64 32`
AUTH_TOKEN=

# Optional: port to listen on (default: 3000)
PORT=3000

# Optional: directory for SQLite database file (default: ./data)
DATA_DIR=./data

# Optional: enable periodic git backups by setting a positive interval in minutes
BACKUP_GIT_INTERVAL_MINUTES=

# Required when backup is enabled: HTTPS remote URL
BACKUP_GIT_URL=

# Required when backup is enabled: HTTPS auth credentials
BACKUP_GIT_USERNAME=
BACKUP_GIT_PASSWORD=

# Optional: backup branch name (default: main)
BACKUP_GIT_BRANCH=main

# Optional: local git worktree directory (default: sibling of DATA_DIR named <DATA_DIR>-git-backup)
BACKUP_GIT_WORKTREE_DIR=

# Optional: git author used for backup commits
BACKUP_GIT_AUTHOR_NAME=obsidian-crdt-sync-server
BACKUP_GIT_AUTHOR_EMAIL=backup@localhost
